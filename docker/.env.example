# Image versions to run (GHCR tags — the `v` is stripped, e.g. `1.0.0-rc4`). Pin to a release.
# Note: coordd currently ships only pre-release tags, and pre-releases don't publish `latest`,
# so pin coordd explicitly rather than relying on `latest`.
COORD_VERSION=1.0.0-rc6
WEB_VERSION=0.2.4

# Your admin wallet address (any account HRP — Cosmos Hub, Osmosis, …) for the /admin panel and
# (under launch_policy=restricted) for seeding the coordinator allowlist. Optional for a plain run;
# REQUIRED for `make dev-seed` — set it to demo account 0's address (run `make dev-accounts` to
# print it). Leave empty to run without admin access.
COORD_ADMIN_ADDRESSES=cosmos19rl4cm2hmr8afy4kldpxz3fka4jguq0auqdal4

# --- Demo seed fixture (`make dev-seed`) -------------------------------------------------------
# Public throwaway mnemonic all 16 demo accounts derive from. INSECURE BY DESIGN — demo only, never
# reuse, never send real funds. Account 0 is admin + coordinator (put its address in
# COORD_ADMIN_ADDRESSES above); see docs/demo.md for the full who's-who.
DEMO_MNEMONIC="abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon about"

# Launch-creation policy for the stack. The demo defaults to `restricted` (creation gated to the
# seeded coordinator allowlist); set `open` to let any authenticated account create launches.
COORD_LAUNCH_POLICY=restricted

# Optional: a shared ops token that enables coordd's /bridge/* endpoints, so you can add
# pre-flight rehearsal by running rehearsald natively with the same token (see the README).
# Empty → the bridge is disabled.
REHEARSAL_OPS_TOKEN=